{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.2",
            "config": {
                "maxExecutionTime": 60,
                "includeFiles": ["config/**", "public/**", "resources/**", "routes/**", "vendor/**", "bootstrap/**", "app/**"]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}